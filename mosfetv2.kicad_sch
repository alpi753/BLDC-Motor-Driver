	(text "Termal Hesaplamalar"
		(exclude_from_sim no)
		(at 67.31 242.062 0)
		(effects
			(font
				(size 5.08 5.08)
			)
		)
		(uuid "7497a767-f55c-46f4-a6a8-6653c4e87806")
	)
	(text "dirençten kılıfı belirsiz kapasitör alınabilir 680uF 63V\nboyutu 21x13\n\n"
		(exclude_from_sim no)
		(at 244.094 20.066 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "807f81cb-935d-4c4b-ac52-4671cd9faf25")
	)
	(text "Sense resistor's voltage drop calculated as:\nVs = Imax * R\nVs = 60 * R  (Imax from datasheet, 66A -> 60A)\nV_SOX: DRV8323 current sense output pin voltage\nGain = 40 (Gain selected maximum bcs of power dissipation on shunt resistors)\nR = 0.001 OHM\nVs = 60 * 0.001 = 0.060 V\n\nV_SOX = Vs * Gain (Gain = 5/10/20/40)\nV_SOX = 0.060 *40 = 2.4 V\n\n2.4 V -> 60A -> 3000 (ADC raw)\n3.3 V -> 82.5A -> 4095 (ADC raw)\ny = 0.02x (y=Amp , x=adc digit)\n\nP = I^2*R = 60^2*0.001\nP = 3.6 W"
		(exclude_from_sim no)
		(at 123.19 179.578 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "a46810e2-2f43-4333-95fc-b81393fb0693")
	)
	(text "WORKING CONDITIONS CONSIDERED AS:\nI = 20 A\nT = 120 C\nBecause of thermal cooling limitations\n\n"
		(exclude_from_sim no)
		(at 79.502 157.226 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "b799bbee-d58b-4223-8c79-9d08d29e9c6a")
	)
	(text "Bu değeri biraza daha düşürebiliriz thermal vialar ile"
