	(text "I = 20A\nRDSON = 0.005 OHM\nPLOSS = I^2 * R\nPLOSS = 2 W\n-----\nRDSON(T=125) = 1.5*0.005 = 0.0075 OHM\nPLOSS = 3 W\n-----\nMOSFET TEMPERATURE\n= 25 + 3 * 31.3\n= 118.9 C\n"
		(exclude_from_sim no)
		(at 87.122 344.678 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "4503539a-9182-493c-a21d-837226809608")
	)
	(text "1.5\n"
		(exclude_from_sim no)
		(at 7.874 271.78 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "5529140f-060c-44a6-b676-3c8f6d6f88b3")
	)
	(text "f(I) = T\ny = I^2*0.0075*31.3+25\ny = 0.23475 * I^2 + 25 "
		(exclude_from_sim no)
		(at 141.986 332.486 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "55c46192-4c3d-4adf-a47c-13ab0f5fdc68")
	)
	(text "Sense resistor's power dissipation calculated as:\nPmax = Imax^2 * R\nPmax = 60^2 * 0.001\nPmax = 3.6 W.\nSo We can use 2 2W resistors. Also we can not achive 60 Amps already."
		(exclude_from_sim no)
		(at 122.936 154.432 0)
